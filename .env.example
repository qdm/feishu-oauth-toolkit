# Feishu app credentials — copy this file to `.env` and fill in your own values.
# The `.env` file is git-ignored.

# App ID (visible in Feishu developer console, looks like `cli_xxxxxxxxxxxx`)
FEISHU_APP_ID=

# App Secret (NEVER commit this — keep .env out of git)
FEISHU_APP_SECRET=

# Optional: override the default token storage path
# FEISHU_TOKEN_FILE=/path/to/feishu-user-tokens.json

# Optional: override the default code-landing path
# FEISHU_CODE_FILE=/path/to/code.txt
